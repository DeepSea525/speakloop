    "sql": "\n-- 创建 conversations 表\nCREATE TABLE IF NOT EXISTS conversations (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  title VARCHAR(255) NOT NULL,\n  source_type VARCHAR(10) NOT NULL CHECK (source_type IN ('paste', 'chat')),\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 创建 messages 表\nCREATE TABLE IF NOT EXISTS messages (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  conversation_id VARCHAR(36) NOT NULL,\n  role VARCHAR(10) NOT NULL CHECK (role IN ('user', 'assistant')),\n  content TEXT NOT NULL,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 创建 extraction_runs 表\nCREATE TABLE IF NOT EXISTS extraction_runs (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  conversation_id VARCHAR(36),\n  model VARCHAR(100) NOT NULL,\n  input_summary TEXT,\n  status VARCHAR(10) NOT NULL DEFAULT 'pending' CHECK (status IN ('pending', 'success', 'error')),\n  error_message TEXT,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 创建 review_items 表\nCREATE TABLE IF NOT EXISTS review_items (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  conversation_id VARCHAR(36),\n  kind VARCHAR(10) NOT NULL CHECK (kind IN ('word', 'phrase', 'sentence', 'issue')),\n  prompt_cn TEXT NOT NULL,\n  answer_en TEXT NOT NULL,\n  explanation TEXT NOT NULL DEFAULT '',\n  tags JSON NOT NULL DEFAULT (JSON_ARRAY()),\n  difficulty INT NOT NULL DEFAULT 2 CHECK (difficulty BETWEEN 1 AND 5),\n  due_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,\n  mastered_at DATETIME,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 创建 review_events 表\nCREATE TABLE IF NOT EXISTS review_events (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  review_item_id VARCHAR(36) NOT NULL,\n  rating VARCHAR(10) NOT NULL CHECK (rating IN ('hard', 'easy', 'mastered')),\n  correct BOOLEAN NOT NULL DEFAULT TRUE,\n  duration_ms INT,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n\n-- 创建 profiles 表\nCREATE TABLE IF NOT EXISTS profiles (\n  user_id VARCHAR(36) PRIMARY KEY,\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  display_name VARCHAR(40) NOT NULL,\n  display_name_normalized VARCHAR(40) NOT NULL UNIQUE,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,\n  updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP\n);\n\n-- 创建 ai_usage_events 表\nCREATE TABLE IF NOT EXISTS ai_usage_events (\n  id VARCHAR(36) PRIMARY KEY DEFAULT (UUID()),\n  _openid VARCHAR(64) DEFAULT '' NOT NULL,\n  user_id VARCHAR(36) NOT NULL,\n  route VARCHAR(100) NOT NULL,\n  model VARCHAR(100) NOT NULL,\n  input_chars INT NOT NULL DEFAULT 0 CHECK (input_chars >= 0),\n  output_chars INT NOT NULL DEFAULT 0 CHECK (output_chars >= 0),\n  status VARCHAR(10) NOT NULL CHECK (status IN ('success', 'error')),\n  error_message TEXT,\n  created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP\n);\n"
